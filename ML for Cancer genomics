# --- Main Execution ---
if __name__ == "__main__":
    
    print("=========================================")
    print("  Machine Learning for Cancer Genomics Demo  ")
    print("=========================================")
    
    # 1. Generate Data
    data_df, features = generate_simulated_data(n_samples=300)
    
    # 2. Train and Evaluate Model
    trained_model = train_and_evaluate_model(data_df, features)
